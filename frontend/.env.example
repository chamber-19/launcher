# GitHub PAT with read:packages scope — required for npm install from GitHub Packages.
# Create at https://github.com/settings/tokens/new (classic, read:packages only).
# Export before running npm install in this directory:
#   export NODE_AUTH_TOKEN=ghp_yourTokenHere   (macOS / Linux)
#   $env:NODE_AUTH_TOKEN = "ghp_yourTokenHere"  (Windows PowerShell)
NODE_AUTH_TOKEN=
