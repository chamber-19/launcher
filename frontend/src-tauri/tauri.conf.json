{
  "$schema": "https://schema.tauri.app/config/2",

  "productName": "Chamber19 Launcher",
  "version": "0.1.0",
  "identifier": "com.chamber-19.launcher",

  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Chamber19 Launcher",
        "width": 1280,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "dragDropEnabled": false,
        "visible": false
      },
      {
        "label": "updater",
        "title": "Chamber19 Launcher — Update",
        "url": "updater.html",
        "width": 520,
        "height": 320,
        "decorations": false,
        "resizable": false,
        "center": true,
        "visible": false
      },
      {
        "label": "splash",
        "title": "Chamber19 Launcher",
        "url": "splash.html",
        "width": 680,
        "height": 460,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "languages": ["English"]
      }
    }
  }
}
